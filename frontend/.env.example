# Set to true or 1 on production until launch (requires rebuild).
VITE_COMING_SOON_MODE=false

# Long random string. Visit once: https://yoursite.com/?csbypass=<same>
# (embedded in client bundle — fine for a soft launch gate, not for secrets.)
# NOTE: this should be removed once the website is going live
# https://yoursite.com/?csbypass=5a02e163c8ea4bf89445c6585c93c635
VITE_COMING_SOON_BYPASS_SECRET=

# Backend API (production). Leave empty in local dev: Vite proxies /api → http://127.0.0.1:8000
# In `npm run dev`, VITE_API_BASE_URL is ignored unless you set VITE_ALLOW_REMOTE_API_IN_DEV=true
# (so a production URL in .env does not break local Django).
# VITE_API_BASE_URL=https://api.example.com
# VITE_ALLOW_REMOTE_API_IN_DEV=true

# Google Sign-In — Web client ID from Google Cloud Console (OAuth 2.0 Client IDs).
# Put this file in frontend/ (not repo root): Vite only loads .env from this directory.
# `npm run dev` uses port 3000 — add http://localhost:3000 under Authorized JavaScript origins.
# VITE_GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com

# Facebook Login — same numeric App ID as backend FACEBOOK_APP_ID (Meta Developer → App settings).
# No certificate files: you only need App ID (public) + App Secret (backend only).
# In Meta: add Facebook Login product; under Settings use cases for localhost + production domains.
# VITE_FACEBOOK_APP_ID=

# Django
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=true

# Database (optional; defaults to sqlite)
# DATABASE_URL=postgres://...

# Google Sign-In — Web client ID (same value as frontend VITE_GOOGLE_CLIENT_ID).
# Copy this file to backend/.env — Django loads it automatically in development.
GOOGLE_OAUTH_CLIENT_ID=

# Sign in with Apple — Services ID (same as frontend VITE_APPLE_CLIENT_ID).
APPLE_CLIENT_ID=

# Facebook Login — same app ID as frontend VITE_FACEBOOK_APP_ID.
# FACEBOOK_APP_SECRET strongly recommended on production (debug_token validation).
# If unset locally, backend still trusts /me email from the browser token (weaker).
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# CORS (comma-separated origins)
# CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# One-time: set to 1 when running `import_local_dump` on Railway, then remove.
# ALLOW_DESTRUCTIVE_IMPORT=1

# TheCocktailDB — optional (default dev key "1" works for imports)
# THECOCKTAILDB_API_KEY=1
